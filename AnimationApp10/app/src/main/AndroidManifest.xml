<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.animationapp">

    <application
        android:allowBackup="true"
        android:icon="@drawable/circle_background"
        android:label="@string/app_name"
        android:roundIcon="@drawable/circle_background"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <!-- ГЛАВНЫЙ ЭКРАН — меню всех заданий -->
        <activity
            android:name=".MenuActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Часть II — базовые анимации -->
        <activity android:name=".MainActivity" />

        <!-- Часть III — Lottie -->
        <activity android:name=".LottieActivity" />

        <!-- Задание 1 — Activity Transition -->
        <activity android:name=".SecondActivity" />

        <!-- Задание 2 — Анимированная кнопка -->
        <activity android:name=".AnimatedButtonActivity" />

        <!-- Задание 3 — RecyclerView -->
        <activity android:name=".RecyclerActivity" />

        <!-- Задание 4 — Progress Indicator -->
        <activity android:name=".ProgressActivity" />

        <!-- Задание 5 — Анимированная иконка -->
        <activity android:name=".AnimatedIconActivity" />

        <!-- Задание 6 — Fragment Transition -->
        <activity android:name=".FragmentTransitionActivity" />

        <!-- Задание 7 — Анимированная карточка -->
        <activity android:name=".AnimatedCardActivity" />

    </application>

</manifest>
